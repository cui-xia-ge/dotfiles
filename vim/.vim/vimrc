" 开启语法高亮
syntax on

" 显示绝对行号
set number

" --- 以下是推荐的进阶配置，让你的编辑器更顺手 ---
" 突出显示当前行
set cursorline

" 设置缩进为 4 个空格
set tabstop=4
set shiftwidth=4
set expandtab

" 启用鼠标支持（可以用鼠标点击定位或滚动）
set mouse=a

" 搜索时高亮匹配项
set hlsearch

" 让vim复制操作也会保存到系统剪切板
set clipboard=unnamedplus

" --- 插件管理区 ---
call plug#begin('~/.vim/plugged')

" 安装 vim-airline 本体
Plug 'vim-airline/vim-airline'
" 安装 vim-airline 主题包（提供多种配色）
Plug 'vim-airline/vim-airline-themes'

call plug#end()

" 配置airline 先安装完再加入
let g:airline_theme='dark'
let g:airline_powerline_fonts = 1
let g:airline#extensions#tabline#enabled = 1
let g:airline#extensions#tabline#formatter = 'default'

" ==========================================
" 自定义 Airline 代理状态指示器
" ==========================================
" 1. 定义一个函数，用于检测环境变量
function! GetProxyStatus()
    " 如果 http_proxy 或 all_proxy 环境变量不为空，则返回火箭图标
    if $http_proxy != '' || $all_proxy != ''
        return '🚀 PROXY '
    endif
    " 否则返回空字符串（什么都不显示）
    return ''
endfunction

" 2. 定义一个初始化函数，将图标挂载到 Airline 上
function! AirlineInit()
    " 在 Airline 中注册名为 proxy_indicator 的新部件，并绑定上面的检测函数
    call airline#parts#define_function('proxy_indicator', 'GetProxyStatus')

    " 将我们的图标注入到 Airline 的 X 区（默认显示文件格式和类型的区域）
    " 并且保留原来的内容（g:airline_section_x），让图标显示在最前面
    let g:airline_section_x = airline#section#create(['proxy_indicator', g:airline_section_x])
endfunction

" 3. 告诉 Vim：在 Airline 插件加载完毕后，立刻执行这个初始化函数
autocmd User AirlineAfterInit call AirlineInit()
